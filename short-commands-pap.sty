% --------------------------------------------------------------------------------------------------------------------------------
%   Wichtige Ergebnisse. Res für finale Ergebnisse. Label müssen überarbeitet werden
% --------------------------------------------------------------------------------------------------------------------------------

% Results \res[Exponent der 10er Potenz]{Ergebniswert}{Fehler des Ergebnisses}{Einheit}
\newcommand{\res}[5][0]{
  \begin{equation}
    % \label{eq:#2}
    \boxed{
        #2 =
      {(#3 \pm #4)}
        \ifthenelse{#1=0}{
            \,
          }{
          \cdot 10^{#1} \,
        }
        \mathrm{#5}
      }
  \end{equation}
}

% Wichtige Zwischenergebnisse, aber keine Endergebnisse
\newcommand{\imp}[5][0]{
  \begin{equation}
    % \label{eq:#2}
    \underline{
        #2 =
      {(#3 \pm #4)}
        \ifthenelse{#1=0}{
            \,
          }{
          \cdot 10^{#1} \,
        }
        \mathrm{#5}
      }
  \end{equation}
}


% ----------------------------------------------------------------
%   Angepasste commands, um schneller Grafiken zu importieren
%   Alle Grafiken sollten im Dateinamen keine Leerzeichen haben, 
%   damit die Label vernünftig funktionieren.
% ----------------------------------------------------------------

% \img[Width]{Path}{Caption}
\newcommand{\img}[3][0.85]{
  \begin{figure}[h!]
    \centering
    \includegraphics[width = #1 \linewidth]{Versuche/\versuchsnummer/img/#2} % Automatisch im Verzeichznis der Versuchsnummer
    \caption{#3}
    \label{fig:#2}
  \end{figure}
}

% \wrap[Width]{Left or Right?}{Path}{Caption}{Label}
\newcommand{\wrap}[4][0.25]{
  \begin{wrapfigure}{#2}{#1\textwidth}
    \centering
    \includegraphics[width = #1 \textwidth]{Versuche/\versuchsnummer/img/#3} % Automatisch im Verzeichznis der Versuchsnummer
    \caption{#4}
    \label{fig:#3}
    \vspace{0.6cm}
  \end{wrapfigure}
}


% \dia[Width]{Path}{Caption}{Label}
\newcommand{\dia}[3][0.95]{
  \begin{diagramm}[h]
    \centering
    \includegraphics[width = #1 \linewidth]{Versuche/\versuchsnummer/img/plot/#2} % Automatisch im Verzeichznis der Versuchsnummer
    \caption{#3}
    \label{dia:#2}
  \end{diagramm}
}

% \afz{Das steht in Anführungszeichen nach deutschen Regel}
\newcommand{\afz}[1]{
  \glqq #1\grqq
}

% ----------------------------------------------------------------
%   Comands spezifisch für ein schöneres und schnelleres citen von, 
%   z.B. Literatur oder Abbildungen
% ----------------------------------------------------------------

% Die Eingabe ist das vergebene Label, z.B. \cabb{label} für eine Abbildung, \ctab{label} für eine Tabelle, \cdig{label} für ein Diagramm und \ceq{label} für eine Gleichung
\newcommand{\cabb}[1]{\hyperref[fig:#1]{Abbildung \ref{fig:#1}}} % Abbildung zitieren
\newcommand{\ctab}[1]{\hyperref[tab:#1]{Tabelle \ref{tab:#1}}} % Tabelle zitieren
\newcommand{\cdig}[1]{\hyperref[dia:#1]{Diagramm \ref{dia:#1}}} % Diagramm zitieren
\newcommand{\ceq}[1]{\hyperref[eq:#1]{Gleichung \ref{eq:#1}}} % Gleichung zitieren
\newcommand{\cch}[1]{\hyperref[ch:#1]{Kapitel \ref{ch:#1}}} % Kaapitel zitieren
\newcommand{\csec}[1]{\hyperref[sec:#1]{Sektion \ref{sec:#1}}} % Sektion zitieren
\newcommand{\cssec}[1]{\hyperref[ssec:#1]{Sektion \ref{ssec:#1}}} % Subektion zitieren



% ----------------------------------------------------------------
%   Comands spezifisch für schnelles schreiben von Formeln
% ----------------------------------------------------------------

\newcommand{\eq}[2]{
   \begin{equation}
    \label{eq:#1}
    #2
  \end{equation}
}

\renewcommand{\d}[1]{
  \text{d} #1
}

