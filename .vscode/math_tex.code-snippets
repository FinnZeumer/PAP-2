		"body": [
			"\\begin{beispielbox}",
			"    $0",
			"\\end{beispielbox}"
		],
		"description": "Insert a styled example box"
	},
	"beweisBox": {
		"scope": "latex",
		"prefix": "\\bewb",
		"body": [
			"\\begin{beweisbox}",
			"    $0",
			"\\end{beweisbox}"
		],
		"description": "Insert a styled proof box"
	},
	"bemerkungBox": {
		"scope": "latex",
		"prefix": "\\bemb",
		"body": [
			"\\begin{bemerkungbox}",
			"    $0",
			"\\end{bemerkungbox}"
		],
		"description": "Insert a styled remark box"
	},
	"motivationBox": {
		"scope": "latex",
		"prefix": "\\motb",
		"body": [
			"\\begin{motivationbox}",
			"    $0",
			"\\end{motivationbox}"
		],
		"description": "Insert a styled motivation box"
	},
	"explanationBox": {
		"scope": "latex",
		"prefix": "\\expb",
		"body": [
			"\\begin{explanation}",
			"    $0",
			"\\end{explanation}"
		],
		"description": "Insert a styled explanation box"
	},

// Here are just styling elements for text, for easier writing.
	"boldText": {
		"scope": "latex",
		"prefix": "\\bl",
		"body": "\\textbf{${1:Important text}}",
		"description": "Bold important text"
	},
	"emphasizeText": {
		"scope": "latex",
		"prefix": "\\emph",
		"body": "\\emph{${1:Emphasized text}}",
		"description": "Emphasized text"
	},
	"italicText": {
		"scope": "latex",
		"prefix": "\\it",
		"body": "\\textit{${1:Italic text}}",
		"description": "Italic text"
	},
	"underlineText": {
		"scope": "latex",
		"prefix": "\\ul",
		"body": "\\underline{${1:Underlined text}}",
		"description": "Underlined text"
	},
	"redText": { //Mostly used for higligting ToDos!
		"scope": "latex",
		"prefix": "\\rtxt",
		"body": "\\textcolor{red}{${1:Red text}}",
		"description": "Red colored text"
	},
}