	},
	"lemmaBox": {
		"scope": "latex",
		"prefix": "\\lemb",
		"body": [
			"\\begin{lemma}[${}]{$2}",
			"    $0",
			"\\end{lemma}"
		],
		"description": "Insert a styled lemma box"
	},
	"korollarBox": {
		"scope": "latex",
